# =============================================================================
# StudentHub Docker Compose 环境变量模板 (Java Spring Boot 版)
# -----------------------------------------------------------------------------
# 使用方式:
#   1. 复制此文件为 .env:   cp deploy/.env.example deploy/.env
#   2. 按实际部署修改敏感项 (APP_DATA_KEY 等)
#   3. .env 已被 .gitignore 排除, 不会入仓
# =============================================================================

# -------- 镜像 / 容器 --------
# 镜像名称 (与 docker-compose.yml 中保持一致)
IMAGE_NAME=studenthub
IMAGE_TAG=latest

# 主机端口 -> 容器内 8080 端口的映射
#  - 修改左侧数字可改对外端口, 右侧不要改
#  - 部署到云服务器时建议改为 80 / 443 (需 root) 或保持高位端口
HOST_PORT=80

# 时区
TZ=Asia/Shanghai

# -------- 后端运行参数 (Spring Boot 读取) --------
# 运行模式: dev / prod (prod 会强制校验 APP_DATA_KEY)
APP_ENV=prod

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# JVM 调优参数
JAVA_OPTS=-Xms512m -Xmx1024m

# -------- 敏感密钥 --------
# 字段级加密密钥 (AES-256-GCM, 32 字节)
#  - 用于身份证号 / 银行卡号 / 家庭经济信息加密 (ADR-011)
#  - 生成示例: openssl rand -base64 32
#  - 妥善保管, 丢失后已加密数据无法解密
APP_DATA_KEY=please-change-me-to-a-32-bytes-base64-aes-key

# -------- CORS 配置 --------
# 允许的前端 Origin 白名单 (逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------- 端口对外暴露配置 --------
# 是否将容器端口发布到主机 (false = 仅在自定义网络中可达)
PUBLISH_PORT=true
